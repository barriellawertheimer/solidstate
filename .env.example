# Public URL where postern is reachable. Include the /contact path.
# Dev (postern running locally):  http://127.0.0.1:8787/contact
# Prod (behind your reverse proxy): https://contact.example.com/contact
VITE_CONTACT_ENDPOINT=http://127.0.0.1:8787/contact

# Cloudflare Turnstile site key (the public one — not the secret).
# Get from https://dash.cloudflare.com → Turnstile.
VITE_TURNSTILE_SITE_KEY=
